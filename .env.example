# ─── Keri CMS – Environment Config ───────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git!

# MySQL / MariaDB connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=keri_user
DB_PASS=keri_pass
DB_NAME=keri_cms

# JWT secret – change this to a long random string in production!
JWT_SECRET=keri_super_secret_change_me_in_prod_2026

# Server port
PORT=3000

# Node environment
NODE_ENV=development
